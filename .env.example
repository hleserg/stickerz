# Copy to .env and fill in. NEVER commit .env.
# Most settings use the APP_ prefix (see src/sticker_service/config.py).
# Secrets also accept the bare names used as repository/CI secrets.

APP_ENVIRONMENT=development
APP_DEBUG=false

# --- Secrets (required to actually run the bot / real generation) ---
# Telegram bot token from @BotFather. Bare alias: BOT_TOKEN
APP_BOT_TOKEN=
# Gemini 3 Pro Image API key (canonical + sticker sheet). Bare alias: GEMINI_KEY
APP_GEMINI_API_KEY=
# GPT Image API key (parallel path, optional, §15.1). Bare alias: GPT_KEY
APP_OPENAI_API_KEY=

# --- Model generation (§8, §15.1) ---
# gemini | gpt | mock  (mock works without any API key)
APP_MODEL_PROVIDER=gemini
# vision_judge | face_geometry | none  (per-style YAML value overrides this)
APP_DEFAULT_GATE=vision_judge
# Outbound proxy for reaching Gemini/GPT from RU (§10). Empty = direct.
APP_MODELS_PROXY_URL=

# --- Access control (§11.1) ---
# Comma-separated Telegram user_ids allowed to run admin commands.
APP_ADMIN_IDS=
# First N approved testers get in automatically in alpha (manual approvals
# count toward the seats). 0 disables auto-approval.
APP_ALPHA_AUTO_APPROVE_LIMIT=30

# --- Maintenance (bound disk/DB growth) ---
# Draft packs and analytics events older than these windows are pruned by the
# maintenance loop (generation_done events are always kept — the alpha budget
# needs the all-time count). 0 disables a sweep.
APP_DRAFT_RETENTION_DAYS=30
APP_EVENTS_RETENTION_DAYS=180
# FSM rows untouched this long are dropped (abandoned mid-wizard flows).
APP_FSM_RETENTION_DAYS=14
# Housekeeping cadence: at boot, then every N hours. <=0 = once at boot only.
APP_MAINTENANCE_INTERVAL_HOURS=24
# Alert admins when the data volume is at least this % full. 0 disables.
APP_DISK_ALERT_THRESHOLD_PCT=80

# --- Flow resilience (watchdog): per-step timeouts in seconds ---
# Hung automated steps must not freeze the flow. On a photo-check timeout we let
# the photo through; on a generation timeout we apologize and let the user retry.
APP_PHOTO_CHECK_TIMEOUT_S=60
APP_GENERATION_TIMEOUT_S=600
# Max simultaneous CPU/RAM-heavy sheet postprocessings (each peaks ~0.6-0.9 GB).
# 2 fits a 4 GB VDS; raise only with RAM to spare. docs/operations/CAPACITY.md
APP_POSTPROCESS_CONCURRENCY=2
# Max concurrent update-handler tasks (long polling). 0 = unbounded.
APP_POLLING_TASKS_LIMIT=64

# --- Meme pool refresh ---
# Days between Gemini trend rewrites of the default-pack meme pool. 0 = off.
APP_MEME_REFRESH_DAYS=7

# --- Showcase ---
# Telegraph demo page: url-button on /start + application screen, line in /help.
# Empty hides it everywhere.
APP_DEMO_PAGE_URL=
# Yuki's welcome letter for alpha testers (url-button on /start in alpha).
APP_ALPHA_WELCOME_URL=https://telegra.ph/Dobro-pozhalovat-v-alfu-06-10

# --- Sentry (optional; empty DSN disables Sentry) ---
APP_SENTRY_DSN=
APP_SENTRY_ENVIRONMENT=development
APP_SENTRY_RELEASE=
# 0.01 in production gives latency traces for ~1% of updates at negligible cost.
APP_SENTRY_TRACES_SAMPLE_RATE=0.0
